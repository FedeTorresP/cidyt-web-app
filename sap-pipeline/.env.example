# ---------------------------------------------------------------------------
# Configuración del pipeline SAP → Firestore
# Copia este archivo a .env y ajusta los valores.
# ---------------------------------------------------------------------------

# Ruta al archivo JSON de la cuenta de servicio de Firebase (service account key).
# Descárgalo desde: Firebase Console → Configuración del proyecto → Cuentas de servicio.
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# (Opcional) ID del proyecto Firebase. Si se omite, se toma del service account.
FIREBASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Nombres de colecciones Firestore (ajústalos a tu esquema del frontend).
# ---------------------------------------------------------------------------
COL_INTERFACE=interface_ipad
COL_PACIENTES=pacientes
COL_SEGUIMIENTOS=seguimientos
COL_VAL_CORPORAL=val_corporal
COL_ESTUDIOS_REALIZAR=estudios_realizar
COL_EMPRESAS=empresas
COL_PAQUETES=paquetes
COL_PAQUETE_DET=paquete_det
COL_PRESTACIONES=prestaciones
COL_PAQUETE_PRESTACION=paquete_prestacion
COL_ESTUDIOS=estudios

# ---------------------------------------------------------------------------
# Valores por defecto del seguimiento (heredados del pipeline legacy PHP).
# ---------------------------------------------------------------------------
DEFAULT_ENTIDAD_ID=10
DEFAULT_TURNO=1
DEFAULT_HORARIO_ID=1
DEFAULT_MEDICO_ID=0
DEFAULT_USER_CREA=SAP

# Número de estudios a generar en paquete_det (legacy: 1..20).
PAQUETE_DET_ESTUDIOS=20

# Zona horaria para timestamps.
TIMEZONE=America/Mexico_City

# Entorno (development | production).
APP_ENV=development
