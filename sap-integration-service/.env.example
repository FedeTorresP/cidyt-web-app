# =============================================================================
# SAP Integration Worker — plantilla de variables de entorno.
#
# 1) Copia este archivo a `.env`:   cp .env.example .env
# 2) Rellena los valores marcados con <...> con datos reales del servidor.
#
# NUNCA subas el archivo `.env` ni el JSON de la Service Account al repositorio
# (ambos están excluidos en .gitignore / .dockerignore).
# =============================================================================

# -----------------------------------------------------------------------------
# API ODATA DE SAP
# -----------------------------------------------------------------------------

# URL completa del endpoint OData a consumir (a través del túnel de Google).
#   Ejemplo: http://localhost:8080/sap/opu/odata/sap/ZCIDYT_SRV/AdmisionSet
ODATA_ENDPOINT=<url_endpoint_odata>

# Parámetros de query OData opcionales (sin el '?' inicial).
#   Ejemplo: $filter=PatFechaCita eq '2026/04/30'&$top=100
ODATA_QUERY_PARAMS=

# Formato de respuesta preferido: application/json | application/xml
ODATA_ACCEPT=application/json

# Autenticación a nivel de aplicación: none | basic | bearer
# (La seguridad de RED ya la maneja el túnel; esto es auth de la API SAP.)
ODATA_AUTH_TYPE=none
# Solo para ODATA_AUTH_TYPE=basic
ODATA_USERNAME=
ODATA_PASSWORD=
# Solo para ODATA_AUTH_TYPE=bearer
ODATA_BEARER_TOKEN=

# Timeout de la petición HTTP en segundos.
REQUEST_TIMEOUT_SECONDS=30
# Verificación de certificado TLS. El túnel suele ser HTTP local → false.
VERIFY_SSL=false

# -----------------------------------------------------------------------------
# POLLING
# -----------------------------------------------------------------------------

# Cada cuántos minutos se consulta el endpoint OData.
POLL_INTERVAL_MINUTES=5

# -----------------------------------------------------------------------------
# FIREBASE
# -----------------------------------------------------------------------------

# ID del proyecto de Firebase / GCP destino.
FIREBASE_PROJECT_ID=<id_proyecto_firebase>

# Ruta ABSOLUTA en el host al .json de la Service Account (se monta :ro).
#   Ejemplo: /etc/cidyt/secrets/firebase-sa.json
GOOGLE_APPLICATION_CREDENTIALS_HOST=<ruta_absoluta_host>/firebase-sa.json

# Ruta a la Service Account DENTRO del contenedor (coincide con el mount).
GOOGLE_APPLICATION_CREDENTIALS=/app/sa.json

# -----------------------------------------------------------------------------
# AUDITORÍA Y LOGGING
# -----------------------------------------------------------------------------

# Valor fijo para los campos createdBy/updatedBy en la ingesta automática.
AUDIT_ACTOR=sap-integration
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
