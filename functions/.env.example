# Configuración de la Cloud Function `relay_sap_to_onprem`.
#
# Copia este archivo a `functions/.env` (carga global) o
# `functions/.env.ipad-cidyt` (solo para el proyecto ipad-cidyt) y rellena los
# valores reales. NUNCA subas el .env con secretos al repositorio.
#
# IMPORTANTE: los SECRETOS no van aquí. Se gestionan con Firebase Secret Manager:
#   firebase functions:secrets:set SAP_INBOUND_API_KEY
#   firebase functions:secrets:set ON_PREM_AUTH_VALUE   # (opcional)

# Región de la función (debe coincidir con la región del conector VPC).
FUNCTION_REGION=us-central1

# Conector de Serverless VPC Access en la VPC compartida `core-red-compartida`.
# En Shared VPC el conector vive en el HOST project: usa el recurso COMPLETO.
#   projects/<HOST_PROJECT_ID>/locations/<REGION>/connectors/<NOMBRE_CONECTOR>
VPC_CONNECTOR=projects/HOST_PROJECT_ID/locations/us-central1/connectors/core-red-compartida-conn

# URL base PRIVADA del sap-pipeline On-Premise (IP/host alcanzable vía VPC).
ON_PREM_BASE_URL=http://10.0.0.10:8000
ON_PREM_PATIENTS_PATH=/patients
ON_PREM_TIMEOUT_SEC=30

# Nombre del header con el que SAP autentica contra esta función.
# El VALOR del secreto se define con: firebase functions:secrets:set SAP_INBOUND_API_KEY
SAP_API_KEY_HEADER=X-API-Key

# (Opcional) Autenticación hacia el endpoint On-Premise.
# Solo el NOMBRE del header va aquí; el VALOR va como secret ON_PREM_AUTH_VALUE.
# Ej.: ON_PREM_AUTH_HEADER=X-API-Key
ON_PREM_AUTH_HEADER=
